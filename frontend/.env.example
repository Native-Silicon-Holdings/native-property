# Supabase Configuration (shared instance)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Authentik → GoTrue SAML SSO domain (registered via POST /admin/sso/providers)
# Used when the login form email is empty; otherwise the email domain is preferred.
VITE_SSO_DOMAIN=nativesilicon.co.za
