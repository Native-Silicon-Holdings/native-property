{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Estate Management Platform",
  "version": "1.0.0",
  "identifier": "com.estatemanagement.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:3000",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Estate Management Platform",
        "width": 1400,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 768,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "center": true,
        "visible": true,
        "hiddenTitle": false,
        "titleBarStyle": "Visible",
        "fileDropEnabled": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://localhost:5000 https://api.estatemanagement.com; img-src 'self' data: blob: https:; style-src 'self' 'unsafe-inline'; font-src 'self' data:; script-src 'self' 'unsafe-inline' 'wasm-unsafe-eval'",
      "dangerousDisableAssetCspModification": false,
      "dangerousRemoteDomainIpcAccess": [],
      "capabilities": ["main-capability"]
    },
    "trayIcon": {
      "id": "main",
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true,
      "menuOnLeftClick": false,
      "title": "Estate Management"
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Business",
    "copyright": "Copyright © 2025 Estate Management Platform",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "shortDescription": "Estate Management Platform",
    "longDescription": "A comprehensive residential estate management solution with property management, maintenance tracking, and facial authentication.",
    "resources": [],
    "externalBin": [],
    "createUpdaterArtifacts": true,
    "publisher": "Estate Management Team",
    "homepage": "https://estatemanagement.com",
    "linux": {
      "deb": {
        "depends": []
      },
      "appimage": {
        "bundleMediaFramework": false
      }
    },
    "macOS": {
      "frameworks": [],
      "minimumSystemVersion": "10.15",
      "exceptionDomain": "localhost",
      "signingIdentity": null,
      "entitlements": null
    },
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "",
      "wix": {
        "language": "en-US"
      },
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "installMode": "perUser",
        "languages": ["en-US"],
        "displayLanguageSelector": false
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://releases.estatemanagement.com/{{target}}/{{arch}}/{{current_version}}"
      ],
      "pubkey": "YOUR_UPDATER_PUBLIC_KEY_HERE"
    }
  }
}
