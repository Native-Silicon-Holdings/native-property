// Prisma Schema for Estate Management Platform

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// User Roles Enum
enum UserRole {
  DIRECTOR
  MANAGER
  HOMEOWNER
  TENANT
  ACCOUNTANT
}

// Users Table
model User {
  id                String   @id @default(uuid())
  email             String   @unique
  passwordHash      String
  firstName         String
  lastName          String
  phoneNumber       String?
  role              UserRole @default(HOMEOWNER)
  isActive          Boolean  @default(true)
  emailVerified     Boolean  @default(false)
  twoFactorEnabled  Boolean  @default(false)
  facialAuthEnabled Boolean  @default(false)
  facialVerified    Boolean  @default(false)
  createdAt         DateTime @default(now())
  lastLogin         DateTime?

  // Relations
  property          Property?              @relation(fields: [propertyId], references: [id])
  propertyId        String?

  documentsUploaded Document[]             @relation("DocumentUploader")
  announcementsPosted Announcement[]
  meetingsCreated   Meeting[]
  readAnnouncements AnnouncementRead[]
  meetingAttendance MeetingAttendance[]
  maintenanceRequests MaintenanceRequest[]
  activityLogs      ActivityLog[]
  facialVerifications FacialVerification[]
  propertyOwnerships PropertyOwnership[]
  propertyAccessRequests PropertyAccessRequest[]
  directorProfile   Director?
  votes             Vote[]
  resolutionsProposed Resolution[]

  @@index([email])
  @@map("users")
}

// Property Types Enum
enum PropertyType {
  HOUSE
  APARTMENT
  TOWNHOUSE
  COMMERCIAL
}

// Ownership Type Enum
enum OwnershipType {
  PRIMARY
  CO_OWNER
  TENANT
  FORMER_OWNER
}

// Property Access Status Enum
enum PropertyAccessStatus {
  PENDING
  APPROVED
  REJECTED
  EXPIRED
}

// Properties Table
model Property {
  id           String       @id @default(uuid())
  unitNumber   String       @unique
  address      String
  propertyType PropertyType
  squareMeters Float
  occupants    Int          @default(1)
  currentPrimaryOwnerId String?

  // Relations
  users        User[]
  utilityReadings UtilityReading[]
  payments     Payment[]
  maintenanceRequests MaintenanceRequest[]
  ownerships  PropertyOwnership[]
  accessRequests PropertyAccessRequest[]

  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([unitNumber])
  @@map("properties")
}

// Document Categories Enum
enum DocumentCategory {
  AGM_MINUTES
  FINANCIAL_REPORTS
  RULES_REGULATIONS
  CONTRACTS
  POLICIES
  OTHER
}

// Document Approval Status Enum
enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

// Documents Table
model Document {
  id              String          @id @default(uuid())
  title           String
  description     String?
  category        DocumentCategory
  fileUrl         String
  fileSize        Int
  version         Int             @default(1)
  tags            String[]
  isArchived      Boolean         @default(false)
  approvalStatus  ApprovalStatus  @default(APPROVED)

  uploadedBy      User            @relation("DocumentUploader", fields: [uploadedById], references: [id])
  uploadedById    String
  uploadedAt      DateTime        @default(now())

  // Relations
  versions        DocumentVersion[]

  @@index([category, uploadedAt])
  @@map("documents")
}

// Document Versions Table
model DocumentVersion {
  id          String   @id @default(uuid())
  documentId  String
  version     Int
  fileUrl     String
  changeNotes String?
  uploadedById String
  uploadedAt  DateTime @default(now())

  // Relations
  document    Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([documentId, version])
  @@map("document_versions")
}

// Announcement Categories Enum
enum AnnouncementCategory {
  URGENT
  MAINTENANCE
  FINANCIAL
  SOCIAL
  GENERAL
}

// Priority Levels Enum
enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

// Announcements Table
model Announcement {
  id                    String                @id @default(uuid())
  title                 String
  content               String
  category              AnnouncementCategory
  priority              Priority              @default(MEDIUM)
  isPinned              Boolean               @default(false)
  requiresAcknowledgment Boolean              @default(false)
  attachments           String[]
  expiresAt             DateTime?

  postedBy              User                  @relation(fields: [postedById], references: [id])
  postedById            String
  postedAt              DateTime              @default(now())

  // Relations
  reads                 AnnouncementRead[]

  @@index([postedAt, category])
  @@map("announcements")
}

// Announcement Reads Table
model AnnouncementRead {
  id              String       @id @default(uuid())
  announcementId  String
  userId          String
  readAt          DateTime     @default(now())
  acknowledged    Boolean      @default(false)

  // Relations
  announcement    Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([announcementId, userId])
  @@map("announcement_reads")
}

// Utility Types Enum
enum UtilityType {
  WATER
  ELECTRICITY
  GAS
  LEVY
  OTHER
}

// Utility Readings Table
model UtilityReading {
  id              String      @id @default(uuid())
  propertyId      String
  utilityType     UtilityType
  readingDate     DateTime
  meterReading    Float
  previousReading Float
  consumption     Float
  rate            Float
  amount          Float
  recordedById    String

  // Relations
  property        Property    @relation(fields: [propertyId], references: [id])

  createdAt       DateTime    @default(now())

  @@index([propertyId, readingDate])
  @@map("utility_readings")
}

// Payment Method Enum
enum PaymentMethod {
  CASH
  BANK_TRANSFER
  CARD
  CHEQUE
  EFT
}

// Payment Status Enum
enum PaymentStatus {
  PENDING
  CLEARED
  BOUNCED
}

// Payments Table
model Payment {
  id            String        @id @default(uuid())
  propertyId    String
  amount        Float
  paymentDate   DateTime
  paymentMethod PaymentMethod
  reference     String
  allocatedTo   Json          // Breakdown by utility/levy
  status        PaymentStatus @default(PENDING)
  receiptUrl    String?

  // Relations
  property      Property      @relation(fields: [propertyId], references: [id])

  createdAt     DateTime      @default(now())

  @@index([propertyId, paymentDate])
  @@map("payments")
}

// Billing Cycle Status Enum
enum BillingCycleStatus {
  OPEN
  CLOSED
  PUBLISHED
}

// Billing Cycles Table
model BillingCycle {
  id          String             @id @default(uuid())
  startDate   DateTime
  endDate     DateTime
  status      BillingCycleStatus @default(OPEN)
  publishedAt DateTime?

  createdAt   DateTime           @default(now())

  @@map("billing_cycles")
}

// Meeting Types Enum
enum MeetingType {
  AGM
  SPECIAL
  BOARD
  COMMITTEE
}

// Meeting Status Enum
enum MeetingStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
}

// Meetings Table
model Meeting {
  id             String        @id @default(uuid())
  title          String
  type           MeetingType
  description    String?
  scheduledDate  DateTime
  location       String
  agendaUrl      String?
  minutesUrl     String?
  status         MeetingStatus @default(SCHEDULED)
  requiredQuorum Int           @default(0)

  createdBy      User          @relation(fields: [createdById], references: [id])
  createdById    String
  createdAt      DateTime      @default(now())

  // Relations
  attendance     MeetingAttendance[]
  resolutions    Resolution[]

  @@index([scheduledDate, status])
  @@map("meetings")
}

// RSVP Status Enum
enum RSVPStatus {
  ATTENDING
  NOT_ATTENDING
  MAYBE
}

// Meeting Attendance Table
model MeetingAttendance {
  id                String      @id @default(uuid())
  meetingId         String
  userId            String
  rsvpStatus        RSVPStatus?
  actualAttendance  Boolean     @default(false)
  proxyFor          String?

  // Relations
  meeting           Meeting     @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  user              User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt         DateTime    @default(now())

  @@unique([meetingId, userId])
  @@map("meeting_attendance")
}

// Maintenance Categories Enum
enum MaintenanceCategory {
  PLUMBING
  ELECTRICAL
  SECURITY
  GARDEN
  CLEANING
  STRUCTURAL
  OTHER
}

// Maintenance Status Enum
enum MaintenanceStatus {
  SUBMITTED
  IN_PROGRESS
  RESOLVED
  CLOSED
}

// Maintenance Requests Table
model MaintenanceRequest {
  id            String              @id @default(uuid())
  propertyId    String
  submittedById String
  category      MaintenanceCategory
  priority      Priority
  description   String
  photos        String[]
  status        MaintenanceStatus   @default(SUBMITTED)
  assignedTo    String?
  estimatedCost Float?
  actualCost    Float?
  rating        Int?
  feedback      String?

  submittedAt   DateTime            @default(now())
  resolvedAt    DateTime?

  // Relations
  property      Property            @relation(fields: [propertyId], references: [id])
  submittedBy   User                @relation(fields: [submittedById], references: [id])

  @@index([propertyId, status])
  @@map("maintenance_requests")
}

// Activity Logs Table
model ActivityLog {
  id        String   @id @default(uuid())
  userId    String
  action    String
  module    String
  details   Json?
  ipAddress String?
  timestamp DateTime @default(now())

  // Relations
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, timestamp])
  @@map("activity_logs")
}

// Facial Verification Status Enum
enum FacialVerificationStatus {
  PENDING
  PROCESSING
  VERIFIED
  FAILED
  EXPIRED
}

// Facial Verification Table
model FacialVerification {
  id                String                   @id @default(uuid())
  userId            String
  videoUrl          String?
  complianceVideoUrl String?
  status            FacialVerificationStatus @default(PENDING)
  verificationScore Float?
  metadata          Json?                    // Store additional verification data
  expiresAt         DateTime?
  verifiedAt        DateTime?
  failureReason     String?

  // Relations
  user              User                     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt

  @@index([userId, status])
  @@map("facial_verifications")
}

// Property Ownership Table
model PropertyOwnership {
  id            String         @id @default(uuid())
  propertyId    String
  userId        String
  ownershipType OwnershipType
  startDate     DateTime       @default(now())
  endDate       DateTime?
  isActive      Boolean        @default(true)

  // Relations
  property      Property       @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@unique([propertyId, userId, startDate])
  @@index([propertyId, isActive])
  @@index([userId, isActive])
  @@map("property_ownerships")
}

// Property Access Request Table
model PropertyAccessRequest {
  id                String                @id @default(uuid())
  propertyId        String
  requestedByUserId String
  requestedForEmail String
  requestedRecords  String[]              // ['utility', 'maintenance', 'documents']
  transferDate      DateTime?
  status            PropertyAccessStatus   @default(PENDING)
  adminNotes        String?
  processedByUserId String?
  processedAt       DateTime?

  // Relations
  property          Property              @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  requestedBy       User                  @relation(fields: [requestedByUserId], references: [id], onDelete: Cascade)

  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

  @@index([propertyId, status])
  @@index([requestedByUserId])
  @@map("property_access_requests")
}

// Director Table
model Director {
  id            String    @id @default(uuid())
  userId        String    @unique
  position      String
  electedDate   DateTime
  termEndDate   DateTime
  portfolio     String?
  biography     String?
  contactEmail  String?
  isActive      Boolean   @default(true)

  // Relations
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([isActive, termEndDate])
  @@index([position])
  @@map("directors")
}

// Election Type Enum
enum ElectionType {
  DIRECTOR
  COMMITTEE
  RESOLUTION
}

// Election Status Enum
enum ElectionStatus {
  UPCOMING
  NOMINATIONS_OPEN
  VOTING_OPEN
  COMPLETED
  CANCELLED
}

// Election Table
model Election {
  id              String          @id @default(uuid())
  title           String
  description     String?
  type            ElectionType
  status          ElectionStatus  @default(UPCOMING)
  nominationsStartDate DateTime
  nominationsEndDate   DateTime
  votingStartDate      DateTime
  votingEndDate         DateTime
  resultsPublishedAt    DateTime?

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  // Relations
  candidates      Candidate[]

  @@index([status, votingEndDate])
  @@map("elections")
}

// Candidate Status Enum
enum CandidateStatus {
  NOMINATED
  ACCEPTED
  WITHDRAWN
}

// Candidate Table
model Candidate {
  id            String          @id @default(uuid())
  electionId   String
  userId        String
  position     String
  statement    String?
  status       CandidateStatus  @default(NOMINATED)
  nominatedBy  String
  secondedBy   String?
  withdrawnAt  DateTime?

  // Relations
  election     Election        @relation(fields: [electionId], references: [id], onDelete: Cascade)
  votes        VoteChoice[]

  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@unique([electionId, userId, position])
  @@index([electionId, status])
  @@map("candidates")
}

// Vote Table
model Vote {
  id          String   @id @default(uuid())
  electionId  String
  userId      String
  candidateId String
  voteHash    String   // SHA-256 hash for audit
  createdAt   DateTime @default(now())

  // Relations
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([electionId, userId])
  @@index([electionId, candidateId])
  @@index([userId])
  @@map("votes")
}

// Vote Choice Table (Aggregated counts)
model VoteChoice {
  id          String   @id @default(uuid())
  electionId  String
  candidateId String
  voteCount   Int      @default(0)

  // Relations
  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([electionId, candidateId])
  @@index([electionId])
  @@map("vote_choices")
}

// Transaction Type Enum
enum TransactionType {
  INCOME
  EXPENSE
}

// Financial Transaction Table
model FinancialTransaction {
  id              String          @id @default(uuid())
  date            DateTime
  type            TransactionType
  category        String
  description     String
  amount          Float
  reference       String?
  accountingPeriod String          // Format: YYYY-Q{1..4}
  attachmentUrl   String?

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([date, type])
  @@index([accountingPeriod])
  @@map("financial_transactions")
}

// Budget Line Table
model BudgetLine {
  id              String   @id @default(uuid())
  fiscalYear     Int
  category       String
  budgetedAmount Float
  spentAmount    Float    @default(0)
  variance       Float    // Calculated: budgetedAmount - spentAmount

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([fiscalYear, category])
  @@index([fiscalYear])
  @@map("budget_lines")
}

// Resolution Status Enum
enum ResolutionStatus {
  PENDING
  PASSED
  FAILED
  DEFERRED
}

// Implementation Status Enum
enum ImplementationStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

// Resolution Table
model Resolution {
  id                  String              @id @default(uuid())
  meetingId           String
  title               String
  description         String
  status              ResolutionStatus    @default(PENDING)
  votesFor            Int                @default(0)
  votesAgainst        Int                 @default(0)
  votesAbstain        Int                 @default(0)
  implementationStatus ImplementationStatus @default(NOT_STARTED)
  proposedBy          String

  // Relations
  meeting             Meeting             @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  proposer            User                @relation(fields: [proposedBy], references: [id])

  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  @@index([meetingId, status])
  @@map("resolutions")
}
