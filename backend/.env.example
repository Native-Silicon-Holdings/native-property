# ================================================================
# ESTATE MANAGEMENT PLATFORM - ENVIRONMENT CONFIGURATION
# ================================================================
# IMPORTANT: Copy this file to .env and update ALL values
# NEVER commit .env to version control!
# ================================================================

# ==================== DATABASE ====================
# PostgreSQL connection string
# Production: Use SSL with sslmode=require
DATABASE_URL="postgresql://user:password@localhost:5432/estate_management?schema=public"

# For production with SSL:
# DATABASE_URL="postgresql://user:password@hostname:5432/estate_management?schema=public&sslmode=require"

# ==================== SERVER ====================
PORT=5000
NODE_ENV="development"  # Options: development, production, test

# ==================== SECURITY - JWT ====================
# CRITICAL: Generate strong random secrets in production!
# To generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

# JWT secret (MUST be at least 32 characters)
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_EXPIRES_IN="24h"
REFRESH_TOKEN_EXPIRES_IN="7d"

# ==================== SECURITY - SESSIONS ====================
# Session secret (MUST be at least 32 characters)
SESSION_SECRET="your-super-secret-session-key-change-this-in-production"

# Cookie secret (MUST be at least 32 characters)
COOKIE_SECRET="your-super-secret-cookie-key-change-this-in-production"

# ==================== SECURITY - ENCRYPTION ====================
# Encryption key for field-level encryption (MUST be at least 32 characters)
# Used for encrypting PII like emails, phone numbers
ENCRYPTION_KEY="your-super-secret-encryption-key-change-this-in-production"
ENCRYPTION_ALGORITHM="aes-256-gcm"

# ==================== SECURITY - PASSWORD POLICY ====================
BCRYPT_ROUNDS=12  # Higher = more secure but slower (10-14 recommended)
PASSWORD_MIN_LENGTH=12  # Enterprise standard: 12+ characters
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION=30  # Minutes

# ==================== SECURITY - HTTPS & CORS ====================
REQUIRE_HTTPS="false"  # Set to "true" in production
COOKIE_DOMAIN=""  # Leave empty for default, or set to your domain
FRONTEND_URL="http://localhost:3000"
ALLOWED_ORIGINS="http://localhost:3000"  # Comma-separated list

# ==================== SECURITY - RATE LIMITING ====================
RATE_LIMIT_WINDOW=15  # Minutes
RATE_LIMIT_MAX_REQUESTS=100  # Max requests per window

# ==================== EMAIL CONFIGURATION ====================
# Options: smtp, sendgrid
EMAIL_SERVICE="smtp"

# SMTP Configuration
EMAIL_HOST="smtp.gmail.com"
EMAIL_PORT=587
EMAIL_USER="your-email@example.com"
EMAIL_PASSWORD="your-email-password"
EMAIL_FROM="Estate Management <noreply@estatemanagement.com>"

# SendGrid Configuration (if using SendGrid)
# SENDGRID_API_KEY="your-sendgrid-api-key"

# ==================== FILE UPLOAD ====================
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE=10485760  # 10MB in bytes

# ==================== LOGGING & MONITORING ====================
# Log level: error, warn, info, debug
LOG_LEVEL="info"

# Sentry DSN (for error tracking in production)
# SENTRY_DSN=""

# ==================== FEATURE FLAGS ====================
ENABLE_FACIAL_AUTH="true"
ENABLE_TWO_FACTOR_AUTH="true"
ENABLE_EMAIL_NOTIFICATIONS="true"

# ==================== CLOUD STORAGE (Optional) ====================
# AWS S3
# AWS_ACCESS_KEY_ID=""
# AWS_SECRET_ACCESS_KEY=""
# AWS_REGION="us-east-1"
# AWS_S3_BUCKET=""

# Azure Blob Storage
# AZURE_STORAGE_CONNECTION_STRING=""
# AZURE_STORAGE_CONTAINER=""

# ==================== BACKUP CONFIGURATION ====================
# BACKUP_ENABLED="true"
# BACKUP_SCHEDULE="0 2 * * *"  # Daily at 2 AM (cron format)
# BACKUP_RETENTION_DAYS=30
# BACKUP_DESTINATION="s3"  # Options: local, s3, azure

# ==================== COMPLIANCE ====================
# Data retention policy (days)
DATA_RETENTION_DAYS=365
LOG_RETENTION_DAYS=90

# GDPR Configuration
GDPR_ENABLED="true"
DATA_EXPORT_ENABLED="true"
RIGHT_TO_DELETION_ENABLED="true"

# ================================================================
# PRODUCTION SECURITY CHECKLIST
# ================================================================
# Before deploying to production, ensure:
# ✅ All secrets are strong random values (32+ characters)
# ✅ DATABASE_URL includes ?sslmode=require
# ✅ REQUIRE_HTTPS="true"
# ✅ NODE_ENV="production"
# ✅ Strong POSTGRES_PASSWORD set
# ✅ BCRYPT_ROUNDS=12 or higher
# ✅ PASSWORD_MIN_LENGTH=12 or higher
# ✅ ALLOWED_ORIGINS restricted to your domain
# ✅ Email configuration tested
# ✅ Backup configuration enabled
# ✅ Monitoring/alerting configured
# ================================================================
